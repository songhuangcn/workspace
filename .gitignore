# Ignore everything except devcontainer config, GitHub workflows, and Makefile
*
!.gitignore
!.devcontainer/
!.devcontainer/**
!.github/
!.github/**
!Makefile

# Secrets and OS files inside .devcontainer
.devcontainer/.env
.devcontainer/config/.ssh/*
.devcontainer/config/.lark-cli/*
.devcontainer/config/gh/*
.devcontainer/data/opencode/*
!**/.keep
.DS_Store
