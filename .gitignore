# Ignore everything except devcontainer config, GitHub workflows, and Makefile
*

!.gitignore
!Makefile
!README.md
!scripts/
!scripts/**
!.devcontainer/
!.devcontainer/**
!.github/
!.github/**

# Secrets and OS files inside .devcontainer
.devcontainer/config/**
.devcontainer/data/**

.env
!**/.keep
.DS_Store
